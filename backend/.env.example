# ── backend environment ──
# copy this file to .env and fill in the values you need.
# the annotate / signature tools run entirely in the browser and need none of this.

# ── required to boot ──
# the server exits on startup unless at least one of these is set (used for summarize).
GROQ_API_KEY=

# ── uploadthing (required for tools that store files: merge, protect, dark mode, etc.) ──
UPLOADTHING_TOKEN=

# ── translation (required only for the translate tool) ──
TRANSLATE_API_KEY=

# ── server ──
# port the api listens on. defaults to 3001.
PORT=3001
# set to "production" to enable rate limiting. defaults to development.
NODE_ENV=development

# ── optional tuning (safe to leave blank, defaults shown) ──
# how long stored files live before cleanup, in minutes. defaults to 45.
FILE_LIFETIME_MINUTES=45
# summarize requests allowed per day. defaults to 10.
SUMMARIZE_RATE_LIMIT_PER_DAY=10
# pages grouped per summarize chunk. defaults to 3.
PAGES_PER_CHUNK=3

# ── optional translation fonts ──
# path to a font for translated pdfs, plus per-language overrides.
# example per language: PDF_TRANSLATION_FONT_HI_PATH for hindi.
PDF_TRANSLATION_FONT_PATH=
